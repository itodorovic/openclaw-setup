# ── DigitalOcean ────────────────────────────────────────────────────────────
do_token          = "dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
ssh_key_path      = "~/.ssh/id_ed25519.pub"
# allowed_ssh_cidrs = ["YOUR_PUBLIC_IP/32"]  # auto-detected if omitted

# ── Cloudflare ──────────────────────────────────────────────────────────────
cloudflare_api_token  = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
cloudflare_account_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
cloudflare_zone_id    = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Domains ─────────────────────────────────────────────────────────────────
domain_name   = "ai.example.com"
status_domain = "status.example.com"
admin_domain   = "admin.example.com"

# ── Access Control ──────────────────────────────────────────────────────────
# email_forward_to is automatically added to the Access policy if set
allowed_emails   = ["admin@example.com"]
email_forward_to = "your.personal@gmail.com"  # Cloudflare Email Routing: admin@example.com → here

# ── Repository ──────────────────────────────────────────────────────────────
repo_clone_url = "https://github.com/itodorovic/openclaw-setup.git"

# ── R2 Backups (optional — uncomment to enable free encrypted backups) ────
# Create R2 API token once: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# Everything else (bucket, endpoint, encryption password) is auto-generated.
# r2_backup_access_key_id     = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # R2 → Manage API Tokens → Access Key ID
# r2_backup_secret_access_key = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # R2 → Manage API Tokens → Secret Access Key

# ── OpenClaw ────────────────────────────────────────────────────────────────
# openclaw_model     = "openai-codex/gpt-5.4"       # ChatGPT Plus via OAuth (default)
# browser_enabled    = true
# extra_apt_packages = "git curl jq gh build-essential python3"  # system tools for plugins

# ── Multi-Agent Orchestration ─────────────────────────────────────────────
# enable_agent_to_agent        = false   # let agents message each other
# subagent_max_spawn_depth     = 1       # 1 = flat, 2 = orchestrator can spawn workers
# subagent_max_concurrent      = 3       # parallel sub-agent runs (keep low on small droplets)
# subagent_run_timeout_seconds = 1800    # 30 min per sub-agent run (0 = no timeout)
