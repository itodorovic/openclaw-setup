{
    # Global options
    auto_https off
}

# --- Main OpenClaw Dashboard ---
http://{$DOMAIN_NAME} {
    reverse_proxy openclaw-gateway:18789 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
    }
}

# --- Admin Console ---
http://{$ADMIN_DOMAIN} {
    reverse_proxy openclaw-gateway:7681 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
    }
}

# --- Docker Log Viewer (Dozzle) ---
http://{$STATUS_DOMAIN} {
    reverse_proxy dozzle:8080 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
    }
}
